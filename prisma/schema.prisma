generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleType {
  GUEST
  CLIENT
  LEGAL_STAFF
  ADMIN
}

enum RequestStatus {
  NEW
  UNDER_REVIEW
  IN_PROGRESS
  COMPLETED
  NEEDS_CLARIFICATION
  CLOSED
}

enum CaseVisibility {
  INTERNAL
  CLIENT_VISIBLE
}

enum PatentStatus {
  SUBMITTED
  REVIEWING
  DOCUMENTS_REQUESTED
  FILED
  PENDING_AUTHORITY_REVIEW
  APPROVED
  REJECTED
  CLOSED
}

enum LandDisputeStatus {
  NEW
  INTAKE_REVIEW
  DOCUMENTS_NEEDED
  UNDER_LEGAL_ASSESSMENT
  CONSULTATION_SCHEDULED
  RESOLVED
  CLOSED
}

enum MonitoringStatus {
  NEW
  UNDER_REVIEW
  MONITORING_ACTIVE
  COMPLETED
  NEEDS_CLARIFICATION
}

enum TrademarkStatus {
  SUBMITTED
  REVIEWING
  DOCUMENTS_REQUESTED
  FILED
  PENDING_AUTHORITY_REVIEW
  APPROVED
  REJECTED
  CLOSED
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  passwordHash    String?
  name            String
  role            RoleType         @default(CLIENT)
  profile         Profile?
  accounts        Account[]
  sessions        Session[]
  serviceRequests ServiceRequest[]
  aiConversations AIConversation[]
  notifications   Notification[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Profile {
  id                   String @id @default(cuid())
  userId               String @unique
  phone                String?
  country              String?
  language             String @default("ar")
  timezone             String?
  notificationsEnabled Boolean @default(true)
  user                 User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceCategory {
  id        String           @id @default(cuid())
  slug      String           @unique
  nameEn    String
  nameAr    String
  requests  ServiceRequest[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model ServiceRequest {
  id         String         @id @default(cuid())
  userId     String?
  categoryId String
  title      String?
  name       String
  email      String
  phone      String?
  country    String?
  message    String
  status     RequestStatus  @default(NEW)
  user       User?          @relation(fields: [userId], references: [id])
  category   ServiceCategory @relation(fields: [categoryId], references: [id])
  case       Case?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([status, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  readAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

model Case {
  id        String              @id @default(cuid())
  title     String
  clientId  String?
  requestId String?             @unique
  status    String              @default("NEW")
  request   ServiceRequest?     @relation(fields: [requestId], references: [id])
  history   CaseStatusHistory[]
  notes     CaseNote[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
}

model CaseStatusHistory {
  id        String   @id @default(cuid())
  caseId    String
  status    String
  note      String?
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model CaseNote {
  id         String         @id @default(cuid())
  caseId     String
  body       String
  visibility CaseVisibility @default(INTERNAL)
  case       Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
}

model PatentRequest {
  id                  String       @id @default(cuid())
  applicantName       String
  country             String
  inventionTitle      String
  inventionSummary    String
  industry            String
  targetJurisdictions String
  notes               String?
  status              PatentStatus @default(SUBMITTED)
  statusHistory       Json?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
}

model TrademarkRequest {
  id             String          @id @default(cuid())
  applicantName  String
  brandName      String
  industry       String
  jurisdictions  String
  existingStatus String?
  notes          String?
  status         TrademarkStatus @default(SUBMITTED)
  statusHistory  Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model LandDisputeRequest {
  id               String            @id @default(cuid())
  clientName       String
  country          String
  propertyLocation String
  disputeType      String
  description      String
  opposingParty    String?
  urgency          String
  status           LandDisputeStatus @default(NEW)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model MonitoringRequest {
  id        String           @id @default(cuid())
  companyName String
  country   String
  industry  String
  purpose   String
  notes     String?
  status    MonitoringStatus @default(NEW)
  ownerId   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  titleEn     String
  titleAr     String
  bodyEn      String
  bodyAr      String
  category    String
  featured    Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FAQ {
  id         String   @id @default(cuid())
  questionEn String
  answerEn   String
  questionAr String
  answerAr   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  company   String?
  quoteEn   String
  quoteAr   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  title     String
  category  String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  AIMessage[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  role           String
  content        String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
}

model ContactInquiry {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  country     String?
  serviceType String?
  message     String
  consent     Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model ActivityLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String
  entityId   String?
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
}
